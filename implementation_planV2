export interface ChaosConfig {
  request: Request;
  delayMs: number;              // artificial delay before request fires
  abortPercentage: number;      // 0-100: chance of random abort
  iterations: number;
  timeoutValidation: boolean;   // verify client-under-test respects timeout
}

export interface ChaosResult {
  iterations: ChaosIteration[];
